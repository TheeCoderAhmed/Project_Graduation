rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPER FUNCTIONS ───────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuth() && getUserRole() == 'admin';
    }

    function isPatient() {
      return isAuth() && getUserRole() == 'patient';
    }

    function isValidClientRole(role) {
      return role in ['patient', 'provider'];
    }

    function isValidRating(value) {
      return value is number && value >= 1 && value <= 5;
    }

    function isValidQuestionnaire(questionnaire) {
      return questionnaire is map
        && questionnaire.keys().hasOnly([
          'waitingTime',
          'serviceQuality',
          'hygiene',
          'staffCommunication'
        ])
        && isValidRating(questionnaire.waitingTime)
        && isValidRating(questionnaire.serviceQuality)
        && isValidRating(questionnaire.hygiene)
        && isValidRating(questionnaire.staffCommunication);
    }

    // ── USERS ──────────────────────────────────────────────────────────────
    // Users can only read/write their OWN document. No cross-user reads.
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId)
        && request.resource.data.keys().hasOnly([
          'uid',
          'fullName',
          'email',
          'role',
          'profilePhotoUrl',
          'bookmarks'
        ])
        && request.resource.data.uid == request.auth.uid
        && isValidClientRole(request.resource.data.role)
        && request.resource.data.bookmarks is list
        && request.resource.data.bookmarks.size() == 0;
      allow update: if isAdmin() || (isOwner(userId)
        // Users can update profile/bookmark fields, but never identity or role.
        && request.resource.data.diff(resource.data)
          .affectedKeys().hasOnly(['fullName', 'profilePhotoUrl', 'bookmarks']));
      allow delete: if false;
    }

    // ── PROVIDERS ──────────────────────────────────────────────────────────
    // Anyone can read. Only admins or the linked owner can write basic fields.
    // averageRating, rankingScore, totalReviews are LOCKED — only Cloud Functions
    // or admin can update them to prevent manipulation.
    match /providers/{providerId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() ||
        (isAuth() && resource.data.ownerId == request.auth.uid
          // Prevent providers from touching their own scores
          && !request.resource.data.diff(resource.data)
              .affectedKeys().hasAny(['averageRating', 'rankingScore', 'totalReviews']));
      allow delete: if isAdmin();
    }

    // ── REVIEWS ────────────────────────────────────────────────────────────
    // Anyone can read. Only patients can create. No editing after submission.
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isPatient()
        // One review per patient/provider pair, enforced by deterministic ID.
        && reviewId == request.auth.uid + '_' + request.resource.data.providerId
        && exists(/databases/$(database)/documents/providers/$(request.resource.data.providerId))
        && request.resource.data.keys().hasOnly([
          'providerId',
          'userId',
          'userName',
          'overallRating',
          'comment',
          'questionnaire',
          'isVerified',
          'createdAt'
        ])
        // Submitted userId must match the authenticated user
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.isVerified == false
        // Rating must be between 1 and 5
        && isValidRating(request.resource.data.overallRating)
        && isValidQuestionnaire(request.resource.data.questionnaire);
      allow update: if false;
      allow delete: if isAdmin() ||
        (isAuth() && resource.data.userId == request.auth.uid);
    }

    // ── RANKING UPDATES (write-only from trusted path) ─────────────────────
    // Block direct client writes to score fields on providers (enforced above).
    // In production, move recalculateRanking() to a Cloud Function.

    // ── DENY EVERYTHING ELSE ───────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
